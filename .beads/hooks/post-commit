#!/bin/bash
# post-commit — trigger Context Collector when Beads data changes (life-43k)
#
# Fires after every `bd` write (close, claim, create, update).
# Debounced to 30s so a busy session doesn't hammer the Netlify function.
#
# Requires BEADS_API_KEY to be set in the shell environment.
# Add to ~/.zshrc or ~/.bashrc:
#   export BEADS_API_KEY=<your key>

COLLECTOR_URL="https://life-organizer-mo.netlify.app/.netlify/functions/collect-world-state"
DEBOUNCE_SECONDS=30
STAMP_FILE="$HOME/.beads-hook-last"

# Always sync to DoltHub on every commit — debounce only gates the Netlify call.
# Chain: project .beads/ → bd repo sync → ~/beads-global → bd dolt push → DoltHub
BGG_DIR="$HOME/beads-global"
if [ -d "$BGG_DIR" ]; then
  (cd "$BGG_DIR" && bd repo sync > /dev/null 2>&1 && bd dolt push > /dev/null 2>&1) &
fi

# Debounce the Netlify call — don't hammer collect-world-state during a busy session
LAST=$(cat "$STAMP_FILE" 2>/dev/null || echo 0)
NOW=$(date +%s)
if [ $((NOW - LAST)) -lt $DEBOUNCE_SECONDS ]; then
  exit 0
fi
echo "$NOW" > "$STAMP_FILE"

# Skip silently if no API key
if [ -z "$BEADS_API_KEY" ]; then
  exit 0
fi

# Now DoltHub is current — Railway pull will get correct data
curl -s -X POST "$COLLECTOR_URL" \
  -H "Authorization: Bearer $BEADS_API_KEY" \
  --max-time 10 \
  > /dev/null 2>&1 &
